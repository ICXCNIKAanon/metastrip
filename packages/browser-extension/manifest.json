{
  "manifest_version": 3,
  "name": "MetaStrip — Auto Metadata Remover",
  "description": "Automatically strip GPS, device info, and hidden metadata from images before uploading. Right-click any image to inspect its metadata.",
  "version": "0.2.0",
  "permissions": ["activeTab", "storage", "contextMenus"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["strip-jpeg.js", "strip-png.js", "strip-webp.js", "inspect.js", "inspect-ui.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}

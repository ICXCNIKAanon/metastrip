{
  "name": "metastrip",
  "version": "0.1.0",
  "private": true,
  "description": "The world's most complete metadata privacy platform — web app, CLI, MCP server, and API",
  "author": "MetaStrip <hello@metastrip.ai>",
  "license": "MIT",
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/mcp-server",
    "packages/web",
    "packages/hooks"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build -w packages/core",
    "build:cli": "npm run build -w packages/cli",
    "build:mcp": "npm run build -w packages/mcp-server",
    "build:web": "npm run build -w packages/web",
    "dev:web": "npm run dev -w packages/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint packages/*/src/**/*.ts",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
